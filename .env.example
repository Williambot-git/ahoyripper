# AhoyRipper — Environment Variables
# Copy this file to .env and fill in your values.
# Docker: pass via -e VAR=value or use a .env file with docker compose.

# ─── AhoyRipper Configuration ────────────────────────────────────────────────

# API key for unlimited usage (bypasses daily quota).
# In production this MUST be set via an environment variable, not stored in code.
# Docker: AHOY_UNLIMITED_KEY=your-secret-key-here
AHOY_UNLIMITED_KEY=

# Custom User-Agent string sent with yt-dlp requests.
# Defaults to a standard Chrome/Windows UA if not set.
# Useful for debugging or when a site blocks the default UA.
# Docker: AHOY_USER_AGENT="Mozilla/5.0 ..."
AHOY_USER_AGENT=

# ─── Optional: Cookies for Authenticated Rips ─────────────────────────────────
# Path to a Netscape-format cookies.txt file for accessing age-restricted or
# login-gated content (YouTube age-restricted videos, Spotify, etc.).
# Mount the file into the container and set the path here.
# See README.md "Passing cookies to yt-dlp" for full instructions.
# COOKIES_PATH=/var/www/ahoyripper/cookies.txt

# ─── Optional: Timeout Overrides ──────────────────────────────────────────────
# Timeout for the info action (metadata fetch, default: 45 seconds).
# The PHP-side timeout fires before yt-dlp's own socket timeout, ensuring
# clean error classification (SOURCE_TIMEOUT) rather than unclassified exits.
# Docker: YTDLP_TIMEOUT=60
YTDLP_TIMEOUT=45

# Timeout for the download action (file download, default: 300 seconds / 5 minutes).
# Downloads are I/O-bound and need a longer timeout than the info action.
# Docker: YTDLP_DOWNLOAD_TIMEOUT=600
YTDLP_DOWNLOAD_TIMEOUT=300

# ─── Optional: Rate Limit Overrides ───────────────────────────────────────────
# Override the daily request quota (default: 5 for unauthenticated users).
# Unauthenticated users always use this limit. Unlimited-key holders bypass it.
# Set to an integer >= 1. AHOY_UNLIMITED_KEY=... bypasses this entirely.
# Docker: QUOTA_DAILY=50
QUOTA_DAILY=5